# Copie este arquivo para ".env" e ajuste os valores para o seu ambiente.
# Em produção (Railway/Render/etc.), configure estas mesmas chaves como
# variáveis de ambiente na plataforma — não use um arquivo .env em produção.

# ---- Servidor ----
PORT=3001
HOST=0.0.0.0
NODE_ENV=development

# ---- Autenticação ----
# Gere um valor forte com: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# Obrigatório quando NODE_ENV=production (o boot falha sem ele).
JWT_SECRET=

# ---- Banco de dados ----
# Em desenvolvimento (padrão): SQLite em arquivo local, nada a configurar.
# DATABASE_PATH=database.sqlite

# Em produção: defina DATABASE_TYPE=postgres e informe a connection string
# (a maioria dos provedores como Railway/Render já injeta DATABASE_URL
# automaticamente ao criar um banco Postgres).
# DATABASE_TYPE=postgres
# DATABASE_URL=postgresql://usuario:senha@host:5432/banco

# Primeiro deploy com um schema novo: defina DB_SYNC=true uma única vez para
# o TypeORM criar/ajustar as tabelas em produção, depois remova a variável.
# DB_SYNC=true

# ---- CORS ----
# Obrigatório quando NODE_ENV=production (o boot falha sem ele).
# Lista de origens do front-end separadas por vírgula.
ALLOWED_ORIGINS=http://localhost:3000
